# Foursquare Places (restaurants & POI search in trip planner)
FOURSQUARE_API_KEY=

# LiteAPI (hotels & flights with real rates — sandbox or production key)
# Sign up at https://liteapi.travel/
LITEAPI_KEY=

# Unsplash (optional — higher-quality destination photos on Recommended page)
# Free at https://unsplash.com/developers — without this, Wikimedia photos are used
UNSPLASH_ACCESS_KEY=

# Ollama (optional — AI day suggestions)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
